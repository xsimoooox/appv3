# URL publique de l'app (domaine de production). Utilisée dans les QR codes et liens partagés.
# En local sur téléphone : http://192.168.x.x:5173
VITE_PUBLIC_APP_URL=

# Serveur Socket.io pour les appels Contacts (défaut : http://localhost:3001)
VITE_SOCKET_URL=http://localhost:3001

# API backend (vide en dev = proxy Vite vers :3001)
# VITE_API_URL=http://localhost:3001

# MongoDB Atlas (OBLIGATOIRE sur Vercel — gratuit sur mongodb.com/cloud/atlas)
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/wakwak?retryWrites=true&w=majority
# JWT_SECRET=une_chaine_secrete_longue_et_aleatoire_32chars

# Alternative Firebase pour les fonctions Vercel (si vous n'utilisez pas MongoDB)
# USE_FIREBASE_DB=1
# FIREBASE_DATABASE_URL=https://votre-projet-default-rtdb.firebaseio.com
# FIREBASE_DATABASE_AUTH_TOKEN=jeton_serveur_firebase

# Clés VAPID (générer : npx web-push generate-vapid-keys)
# À placer aussi dans un fichier .env à la racine pour server.cjs
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:contact@wakwak.app

# TURN recommandé pour garantir l'audio WebRTC sur les réseaux restrictifs
# VITE_TURN_URL=turn:turn.example.com:3478
# VITE_TURN_USERNAME=
# VITE_TURN_CREDENTIAL=
# PORT=3001
# WAKWAK_API_URL=http://localhost:3001
